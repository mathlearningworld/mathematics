# ──────────────────────────────────────────────
# Mathematics Platform — Root Environment
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env files to version control.

# PostgreSQL connection (used by Docker Compose and Prisma)
POSTGRES_USER=mathematics_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=mathematics

# Backend
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://mathematics_user:change_me_in_production@127.0.0.1:5433/mathematics
LOG_LEVEL=info
